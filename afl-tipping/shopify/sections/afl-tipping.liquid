{% comment %}
  AFL Tipping Section
  Add to any page via Online Store > Customize > Add section > AFL Tipping
  Set the API Base URL in section settings to your Vercel deployment URL.
{% endcomment %}

<div class="afl-tipping-section page-width">
  {%- if section.settings.heading != blank -%}
    <h2 class="afl-tipping-section__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p class="afl-tipping-section__subheading">{{ section.settings.subheading }}</p>
  {%- endif -%}

  <div
    id="afl-tipping-root"
    data-api-url="{{ section.settings.api_url | remove: '/' | append: '' }}"
  >
    <div class="afl-tip-loading">Loading this week&rsquo;s games&hellip;</div>
  </div>
</div>

{{ 'section-afl-tipping.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-afl-tipping.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "AFL Tipping",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "API Base URL",
      "info": "Your Vercel deployment URL, e.g. https://afl-tipping-xxx.vercel.app",
      "default": "https://your-app.vercel.app"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "AFL Tipping"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Pick this week's winners. Tip 6 or more correctly to earn a discount on the AFL collection!"
    }
  ],
  "presets": [
    {
      "name": "AFL Tipping"
    }
  ]
}
{% endschema %}
